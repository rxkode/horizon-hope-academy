# ── App ──────────────────────────────────────────
APP_NAME="Horizon Hope Academy API"
APP_ENV=development
DEBUG=true
SECRET_KEY=change-this-to-a-random-64-char-string-in-production
ALLOWED_ORIGINS=http://localhost:3000

# ── PostgreSQL ───────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=hhacademy
POSTGRES_PASSWORD=hhacademy_dev_password
POSTGRES_DB=horizon_hope_db
DATABASE_URL=postgresql+asyncpg://hhacademy:hhacademy_dev_password@localhost:5432/horizon_hope_db

# ── Redis ────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT ──────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256

# ── Kenya DPA Compliance ─────────────────────────
DATA_RETENTION_DAYS=365
STUDENT_DATA_ENCRYPTED=true
